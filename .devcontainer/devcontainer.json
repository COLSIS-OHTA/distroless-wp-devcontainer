{
  "name": "distroless-wp",
  "dockerComposeFile": [
    "../docker-compose.yml",
    "docker-compose.yml"
  ],
  "service": "dev",
  "workspaceFolder": "/workspaces/distroless-wp",
  "remoteUser": "node",
  "updateRemoteUserUID": true,
  "runServices": [
    "dev",
    "php",
    "wp-cli",
    "webserver",
    "database",
    "phpmyadmin",
    "mail"
  ],
  "forwardPorts": [
    "webserver:80",
    "webserver:443",
    "phpmyadmin:80",
    "phpmyadmin:443",
    "mail:8025"
  ],
  "portsAttributes": {
    "webserver:80": {
      "label": "WordPress (HTTP)",
      "onAutoForward": "openBrowser",
      "visibility": "public"
    },
    "webserver:443": {
      "label": "WordPress (HTTPS)",
      "onAutoForward": "notify",
      "visibility": "public"
    },
    "phpmyadmin:80": {
      "label": "phpMyAdmin (HTTP)",
      "onAutoForward": "notify",
      "visibility": "private"
    },
    "phpmyadmin:443": {
      "label": "phpMyAdmin (HTTPS)",
      "onAutoForward": "silent",
      "visibility": "private"
    },
    "mail:8025": {
      "label": "Mailpit",
      "onAutoForward": "notify",
      "visibility": "private"
    }
  },
  "otherPortsAttributes": {
    "onAutoForward": "ignore"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "bmewburn.vscode-intelephense-client",
        "editorconfig.editorconfig",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "stylelint.vscode-stylelint"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "files.eol": "\n"
      }
    }
  },
  "containerEnv": {
    "BUILDX_NO_DEFAULT_ATTESTATIONS": "1",
    "COMPOSE_BAKE": "false"
  },
  "postCreateCommand": "node -v && npm -v && pnpm -v && safe-chain --version",
  "postStartCommand": "bash .devcontainer/scripts/print-service-urls.sh",
  "shutdownAction": "stopCompose"
}
